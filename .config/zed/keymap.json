// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-f": "file_finder::Toggle",
    },
  },
  {
    "context": "Workspace && !(vim_mode == insert) && !Terminal",
    "bindings": {
      "space space": "file_finder::Toggle",
    },
  },
  {
    "context": "Workspace && vim_mode == normal",
    "bindings": {
      "shift h": "panel::NextPanelTab",
      "space space": "file_finder::Toggle",
    },
  },
  {
    "context": "vim_mode == normal",
    "bindings": {
      "space e": "pane::RevealInProjectPanel",
    },
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      // Window Splits
      "space w v": "pane::SplitVertical",
      "space w h": "pane::SplitHorizontal",
      "space l f": "editor::Format",

      // File Finding
      "space space": "file_finder::Toggle",
      "space s": "workspace::NewSearch",

      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight",

      "ctrl-w q": "pane::CloseActiveItem",
      "space c": "pane::CloseActiveItem",
      "space b d d": "pane::CloseActiveItem",
      "space b d l": "pane::CloseItemsToTheRight",
      "space b d h": "pane::CloseItemsToTheLeft",
      "space b d a": "pane::CloseAllItems",
      "space b d o": "pane::CloseOtherItems",

      // Git
      "space t g b i": "editor::ToggleGitBlameInline",
    },
  },
  {
    "context": "Editor && vim_mode == normal && !diffs_expanded",
    "bindings": {
      "space t g d": "editor::ExpandAllDiffHunks",
    },
  },
  {
    "context": "Editor && vim_mode == normal && diffs_expanded",
    "bindings": {
      "space t g d": "editor::CollapseAllDiffHunks",
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "j k": "vim::NormalBefore",
      "k j": "vim::NormalBefore",
    },
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "space v": "project_panel::OpenSplitVertical",
      "space h": "project_panel::OpenSplitHorizontal",
      "ctrl-g": "git::FileHistory",
    },
  },
  {
    "context": "vim_mode == normal || vim_mode == visual",
    "bindings": {
      "s": "vim::PushSneak",
      "shift-s": "vim::PushSneakBackward",
    },
  },
  {
    "context": "vim_operator == a || vim_operator == i || vim_operator == cs",
    "bindings": {
      // Traditional Vim behavior
      "q": "vim::AnyQuotes",
      "b": "vim::AnyBrackets",

      // mini.ai plugin behavior
      "Q": "vim::MiniQuotes",
      "B": "vim::MiniBrackets",
    },
  },
]
