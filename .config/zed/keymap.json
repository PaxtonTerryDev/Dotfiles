// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-f": "file_finder::Toggle",
      "ctrl-\\": "zed::OpenKeymapFile",
    },
  },
  {
    "context": "vim_mode == normal",
    "bindings": {
      "space e": "pane::RevealInProjectPanel",
    },
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      // File saving
      "space w": "workspace::Save",
      "space W": "workspace::SaveAll",

      // Formatting
      "space f": "editor::Format",

      // File Finding
      "space space": "file_finder::Toggle",
      "space s": "workspace::NewSearch",

      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight",

      "ctrl-w q": "pane::CloseActiveItem",
      "space c": "pane::CloseActiveItem",
      "space shift-c": "pane::CloseOtherItems",
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "j k": "vim::NormalBefore",
    },
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "ctrl-v": "project_panel::OpenSplitVertical",
      "ctrl-h": "project_panel::OpenSplitHorizontal",
      "ctrl-g": "git::FileHistory",
    },
  },
  {
    "context": "vim_mode == normal || vim_mode == visual",
    "bindings": {
      "s": "vim::PushSneak",
      "shift-s": "vim::PushSneakBackward",
    },
  },
  {
    "context": "vim_operator == a || vim_operator == i || vim_operator == cs",
    "bindings": {
      // Traditional Vim behavior
      "q": "vim::AnyQuotes",
      "b": "vim::AnyBrackets",

      // mini.ai plugin behavior
      "Q": "vim::MiniQuotes",
      "B": "vim::MiniBrackets",
    },
  },
]
