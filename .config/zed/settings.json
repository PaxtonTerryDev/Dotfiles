// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true
    }
  },
  "buffer_font_family": "Iosevka Nerd Font Mono",
  "git_panel": {
    "tree_view": true,
  },
  "ui_font_family": "Iosevka Nerd Font Mono",
  "ui_font_size": 14,
  "ui_font_weight": 400,
  "buffer_font_size": 13,
  "buffer_font_weight": 100.0,
  "buffer_line_height": {
    "custom": 1.25,
  },

  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Gruber Darker",
  },

  "cursor_blink": false,

  "vim_mode": true,
  "relative_line_numbers": "disabled",
  "vim": {
    "use_smartcase_find": true,
    "use_system_clipboard": "on_yank",
  },

  "features": {},
  "show_edit_predictions": false,
  "inlay_hints": null,
  "telemetry": {
    "metrics": false,
    "diagnostics": false,
  },
  "tab_bar": {
    "show": true,
  },
  "scrollbar": {
    "show": "never",
  },
  "indent_guides": {
    "enabled": true,
  },

  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
    },
  },

  // "wrap_guides": [120],
  // "show_wrap_guides": true,

  "format_on_save": "on",

  "git_hosting_providers": [
    {
      "provider": "github",
      "name": "PaxtonTerryDev",
      "base_url": "https://github.com/ITDeptUtahCountyGovernment",
    },
    {
      "provider": "github",
      "name": "PaxtonTerryDev",
      "base_url": "https://github.com/PaxtonTerryDev",
    },
  ],
}
